    {
      "name": "Get Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "\r",
              "    pm.response.to.have.status(200);\r",
              "\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 3000ms\", function () {\r",
              "\r",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);\r",
              "\r",
              "});\r",
              "\r",
              "pm.test(\"Firstname is Ryan\", function () {\r",
              "\r",
              "    const response = pm.response.json();\r",
              "\r",
              "    pm.expect(response.firstname).to.eql(\"Ryan\");\r",
              "\r",
              "});\r",
              "\r",
              "pm.test(\"Lastname is Nobrega\", function () {\r",
              "\r",
              "    const response = pm.response.json();\r",
              "\r",
              "    pm.expect(response.lastname).to.eql(\"Nobrega\");\r",
              "\r",
              "});\r",
              "\r",
              "pm.test(\"Total price is 500\", function () {\r",
              "\r",
              "    const response = pm.response.json();\r",
              "\r",
              "    pm.expect(response.totalprice).to.eql(500);\r",
              "\r",
              "});\r",
              "\r",
              "pm.test(\"Deposit paid is true\", function () {\r",
              "\r",
              "    const response = pm.response.json();\r",
              "\r",
              "    pm.expect(response.depositpaid).to.eql(true);\r",
              "\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
